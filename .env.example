# Django
SECRET_KEY=change-me-generate-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database
POSTGRES_DB=workbench
POSTGRES_USER=workbench
POSTGRES_PASSWORD=change-me-in-production

# App port (Dokploy's reverse proxy will bind here)
APP_PORT=8000

# Optional: superuser bootstrap — set once, then remove or leave unset
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me
